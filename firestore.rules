rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/services
    // Fields:
    //   - id: string (required)
    //   - nome: string (required, < 100 chars)
    //   - valor: number (required, > 0)
    //
    // Collection: users/{userId}/products
    // Fields:
    //   - id: string (required)
    //   - nome: string (required, < 100 chars)
    //   - valor: number (required, > 0)
    //
    // Collection: users/{userId}/contacts
    // Fields:
    //   - id: string (required)
    //   - nome: string (required, < 100 chars)
    //   - telefone: string (required, < 20 chars)
    //   - criadoEm: number (required)
    //   - atualizadoEm: number (required)
    //
    // Collection: users/{userId}/history
    // Fields:
    //   - id: string (required)
    //   - descricao: string (required, < 500 chars)
    //   - valor: number (required, > 0)
    //   - tipo: string (required, 'entrada' | 'saida')
    //   - data: string (required, ISO date string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "renansantosbarbearia@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
       return request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen;
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }

    function hasOnlyAllowedFields(fields) {
       return request.resource.data.keys().hasOnly(fields);
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /services/{serviceId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'valor']) && hasOnlyAllowedFields(['id', 'nome', 'valor']) && validStringLength('nome', 1, 100) && isPositive('valor');
        allow update: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'valor']) && hasOnlyAllowedFields(['id', 'nome', 'valor']) && validStringLength('nome', 1, 100) && isPositive('valor') && isImmutable('id');
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /products/{productId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'valor']) && hasOnlyAllowedFields(['id', 'nome', 'valor']) && validStringLength('nome', 1, 100) && isPositive('valor');
        allow update: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'valor']) && hasOnlyAllowedFields(['id', 'nome', 'valor']) && validStringLength('nome', 1, 100) && isPositive('valor') && isImmutable('id');
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /contacts/{contactId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'telefone', 'criadoEm', 'atualizadoEm']) && hasOnlyAllowedFields(['id', 'nome', 'telefone', 'criadoEm', 'atualizadoEm']) && validStringLength('nome', 1, 100) && validStringLength('telefone', 1, 20);
        allow update: if isOwner(userId) && hasRequiredFields(['id', 'nome', 'telefone', 'criadoEm', 'atualizadoEm']) && hasOnlyAllowedFields(['id', 'nome', 'telefone', 'criadoEm', 'atualizadoEm']) && validStringLength('nome', 1, 100) && validStringLength('telefone', 1, 20) && isImmutable('id') && isImmutable('criadoEm');
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /history/{recordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'descricao', 'valor', 'tipo', 'data']) && hasOnlyAllowedFields(['id', 'descricao', 'valor', 'tipo', 'data', 'clienteNome', 'clienteTelefone', 'recorrencia', 'categoria']) && validStringLength('descricao', 1, 500) && isPositive('valor') && request.resource.data.tipo in ['entrada', 'saida'];
        allow update: if isOwner(userId) && hasRequiredFields(['id', 'descricao', 'valor', 'tipo', 'data']) && hasOnlyAllowedFields(['id', 'descricao', 'valor', 'tipo', 'data', 'clienteNome', 'clienteTelefone', 'recorrencia', 'categoria']) && validStringLength('descricao', 1, 500) && isPositive('valor') && request.resource.data.tipo in ['entrada', 'saida'] && isImmutable('id');
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
